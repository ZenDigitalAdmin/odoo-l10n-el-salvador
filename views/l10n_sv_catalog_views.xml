            <field name="model">l10n_sv.tipo_establecimiento</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="code"/>
                            <field name="name"/>
                            <field name="active"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="action_l10n_sv_tipo_establecimiento" model="ir.actions.act_window">
            <field name="name">Tipos de Establecimiento (CAT-009)</field>
            <field name="res_model">l10n_sv.tipo_establecimiento</field>
