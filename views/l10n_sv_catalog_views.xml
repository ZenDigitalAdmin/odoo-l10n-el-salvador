        <record id="view_l10n_sv_tipo_establecimiento_tree" model="ir.ui.view">
            <field name="name">l10n_sv.tipo_establecimiento.list</field>
            <field name="model">l10n_sv.tipo_establecimiento</field>
            <field name="arch" type="xml">
                <list editable="top">
                    <field name="code"/>
                    <field name="name"/>
                    <field name="active" widget="boolean_toggle"/>
                </list>
            </field>
        </record>
