<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <record id="view_l10n_sv_dte_send_wizard_form" model="ir.ui.view">
            <field name="name">l10n_sv.dte.send.wizard.form</field>
            <field name="model">l10n_sv.dte.send.wizard</field>
            <field name="arch" type="xml">
                <form string="Envío Masivo DTE">
                    <header>
                        <field name="state" widget="statusbar" statusbar_visible="draft,done"/>
                    </header>
                    <sheet>
                        <group invisible="state == 'done'">
                            <field name="move_ids" colspan="2"
                                   domain="[('move_type', 'in', ('out_invoice', 'out_refund')), ('state', '=', 'posted'), ('l10n_sv_dte_state', '!=', 'processed'), ('l10n_sv_dte_state', '!=', 'invalidated')]">
                                <list>
                                    <field name="name"/>
                                    <field name="partner_id"/>
                                    <field name="invoice_date"/>
                                    <field name="amount_total"/>
                                    <field name="l10n_sv_dte_tipo_doc"/>
                                    <field name="l10n_sv_dte_state" widget="badge"
                                           decoration-info="l10n_sv_dte_state in ('json_generated', 'signed', 'sent')"
                                           decoration-success="l10n_sv_dte_state == 'processed'"
                                           decoration-danger="l10n_sv_dte_state == 'rejected'"
                                           decoration-warning="l10n_sv_dte_state == 'contingencia'"/>
                                </list>
                            </field>
                            <field name="include_draft"/>
                        </group>
                        <group invisible="state != 'done'">
                            <group>
                                <field name="total_count" readonly="1"/>
                                <field name="success_count" readonly="1" widget="badge"
                                       decoration-success="success_count == total_count"
                                       decoration-warning="success_count != total_count and success_count > 0"
                                       decoration-danger="success_count == 0"/>
                                <field name="failed_count" readonly="1" widget="badge"
                                       decoration-danger="failed_count > 0"/>
                            </group>
                        </group>
                        <notebook invisible="state != 'done'">
                            <page string="Detalle">
                                <field name="line_ids" nolabel="1" readonly="1">
                                    <list decoration-danger="not success"
                                          decoration-success="success">
                                        <field name="name"/>
                                        <field name="partner_id"/>
                                        <field name="state"/>
                                        <field name="success" widget="boolean_toggle"/>
                                        <field name="message"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <footer>
                        <button name="action_send" string="Procesar Facturas"
                                type="object" class="btn-primary"
                                invisible="state == 'done'"/>
                        <button string="Cerrar" class="btn-secondary"
                                special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_l10n_sv_dte_send_wizard" model="ir.actions.act_window">
            <field name="name">Envío Masivo DTE</field>
            <field name="res_model">l10n_sv.dte.send.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

        <menuitem id="menu_l10n_sv_dte_send_wizard"
                  name="Envío Masivo DTE"
                  parent="menu_l10n_sv_root"
                  action="action_l10n_sv_dte_send_wizard"
                  sequence="20"/>

    </data>
</odoo>
